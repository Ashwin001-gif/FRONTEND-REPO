# Frontend Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (REQUIRED for deployment)
# For local development: http://127.0.0.1:5000/api
# For production: https://your-render-app.onrender.com/api
VITE_API_URL=http://127.0.0.1:5000/api

# Socket.io URL (REQUIRED for deployment)
# For local development: http://127.0.0.1:5000
# For production: https://your-render-app.onrender.com
VITE_SOCKET_URL=http://127.0.0.1:5000
